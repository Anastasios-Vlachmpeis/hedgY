# Frontend env (Next.js — server-side only, never shipped to the browser).
# Copy to .env.local and fill in:   cp web/.env.example web/.env.local

# Python aggregator base URL (Kalshi + Polymarket -> /markets, /suggestions).
# Optional: defaults to http://localhost:8000 when unset.
MARKETS_API_URL=http://localhost:8000

# Alpaca paper-trading keys — power live "Trending Stocks" + the account portfolio.
# WITHOUT them the dashboard/markets gracefully fall back to mock numbers
# (prediction markets stay fully live either way — they need no keys).
# Free paper keys: https://app.alpaca.markets  ->  Paper Trading -> API Keys.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
