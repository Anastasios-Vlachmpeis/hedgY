# connections/.env.example — credentials for the account connectors.
# Copy to .env (repo root) and fill in. The manual, Solana, and Polymarket
# connectors need NO keys. The rest need a partner/API account.

# --- Brokerages (Robinhood, IBKR, Schwab, Fidelity, Webull…) via SnapTrade ---
# Get from https://dashboard.snaptrade.com
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# --- Crypto exchanges (Binance, Coinbase, Kraken…) via Mesh Connect ---
# Get from https://dashboard.meshconnect.com
MESH_CLIENT_ID=
MESH_CLIENT_SECRET=

# --- EVM wallets (MetaMask/Rabby) via Zerion ---
# Get from https://zerion.io/api  (Solana/Phantom needs NO key)
ZERION_API_KEY=

# --- Solana wallet (Phantom): optional, richer USD pricing ---
# Public RPC works without this; Helius gives USD-valued tokens.
HELIUS_API_KEY=
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Kalshi positions ---
KALSHI_EMAIL=
KALSHI_PASSWORD=
