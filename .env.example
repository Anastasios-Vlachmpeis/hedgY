# Env for the standalone connectivity smoke tests in scripts/.
# Copy to .env and fill in:   cp .env.example .env
#
#   npm run alpaca:test   # account + quotes + a paper order (needs Node >=22.6 to run .ts)
#   npm run poly:test     # Polymarket reads — auth-free, no keys needed
#
# Free Alpaca paper keys: https://app.alpaca.markets -> Paper Trading -> API Keys.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Optional overrides (defaults shown):
# ALPACA_TRADING_URL=https://paper-api.alpaca.markets
# ALPACA_DATA_URL=https://data.alpaca.markets
