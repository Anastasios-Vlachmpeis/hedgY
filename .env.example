# Copy to .env and fill in Alpaca paper keys for live stock quotes/charts.
# Polymarket reads work without keys (proxied through Vite).
#
#   npm run dev
#
# Free Alpaca paper keys: https://app.alpaca.markets -> Paper Trading -> API Keys
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Optional overrides:
# ALPACA_DATA_URL=https://data.alpaca.markets
